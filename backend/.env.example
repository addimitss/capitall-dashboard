# LLM provider: groq | bedrock
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AWS Bedrock (future)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload limits
MAX_UPLOAD_MB=50

# Schema validation (true = reject workbooks not matching the canonical 9-sheet AML layout)
STRICT_SCHEMA=false

# Auth (false = anonymous; true requires login + bearer token)
AUTH_ENABLED=false
AUTH_SECRET=replace-with-32+char-random-secret-for-prod
